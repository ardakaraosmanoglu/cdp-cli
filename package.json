    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": ["cli", "developer-tools", "terminal", "productivity", "cd"],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
