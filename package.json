{
  "name": "cdproject",
  "version": "0.1.0",
  "description": "Fast project directory switch helper",
  "type": "module",
  "bin": {
    "cdp": "./bin/cdp.js"
  },
  "files": [
    "bin",
    "dist",
    "scripts",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --enable-source-maps ./bin/cdp.js",
    "test": "node --test",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": ["cli", "developer-tools", "terminal", "productivity", "cd", "project-switcher"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ardakaraosmanoglu/cdp-cli"
  },
  "bugs": {
    "url": "https://github.com/ardakaraosmanoglu/cdp-cli/issues"
  },
  "author": "Arda Karaosmanoglu <ardakaraosmanoglu@outlook.com>",
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
