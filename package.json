{
  "name": "cdp-cli",
  "version": "0.1.0",
  "description": "Fast project directory switch helper",
  "type": "module",
  "bin": {
    "cdp": "./bin/cdp.js"
  },
  "files": [
    "bin",
    "dist",
    "scripts",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
